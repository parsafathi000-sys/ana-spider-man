# ===========================================================================
# Spider Panel — environment configuration
# Copy to `.env` and adjust. NOTHING is hardcoded in code; all values come
# from the environment (12-factor). Railway injects most of these for you.
# ===========================================================================

# ---------------- Web server ----------------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ---------------- Secrets / auth (REQUIRED in prod) ----------------
# Generate a strong secret:  python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=
# First-run admin (created automatically if no admin exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_EMAIL=

# ---------------- Database ----------------
# Dev (SQLite, zero setup):
DATABASE_URL=sqlite+aiosqlite:///./data/spider.db
# Prod (PostgreSQL on Railway — Railway provides DATABASE_URL automatically):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# ---------------- Xray core ----------------
XRAY_BINARY_PATH=/usr/local/bin/xray
XRAY_PORT=443
XRAY_CONFIG_PATH=

# ---------------- Public link host ----------------
# On Railway these are auto-injected; the app reads them to build client links.
RAILWAY_TCP_PROXY_DOMAIN=
RAILWAY_TCP_PROXY_PORT=
# Optional vanity base (e.g. your own domain). If set, overrides the above.
PUBLIC_URL=

# ---------------- Data directory ----------------
DATA_DIR=./data

# ---------------- CORS (optional, comma separated) ----------------
CORS_ORIGINS=
